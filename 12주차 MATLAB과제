%(D)
shading interp
colorbar
%(E)
xlabel('x-axis')
ylabel('y-axis')
zlabel('z=f(x,y)')
%(F)
title('Detailed Surface Plot of a Multivariable Function')
%(G)
grid on
set(gca, 'FontSize', 12)
%(H)
view(45, 30)
%(I)
hold on
s2 = surf(X, Y, zeros(size(Z)), 'FaceAlpha', 0.3, 'EdgeColor', 'none');
%(J)
