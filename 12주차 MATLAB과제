maxPoint = [X(row_max(1), col_max(1)), Y(row_max(1), col_max(1)), maxZ]

[row_min, col_min] = find(Z == minZ);
minPoint = [X(row_min(1), col_min(1)), Y(row_min(1), col_min(1)), minZ]

%(L)
p1 = plot3(maxPoint(1), maxPoint(2), maxPoint(3), 'r*', 'MarkerSize', 15, 'LineWidth', 2);
p2 = plot3(minPoint(1), minPoint(2), minPoint(3), 'b^', 'MarkerSize', 15, 'LineWidth', 2);
