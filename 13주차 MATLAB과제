문제4
clc;clear;
%(A)
rng(42);
orders = zeros(1, 365);
for d = 1:365
    L = exp(-180);
    p = 1; k = 0;
    while p > L
        p = p * rand;
        k = k + 1;
    end
    orders(d) = k - 1;
end
%(B)
total_time = zeros(1, 365);
for d = 1:365
    t = randn(1, orders(d)) * 2 + 6;
    t(t < 0) = 0;
    total_time(d) = sum(t);
end
%(C)
sum(total_time > 1200) / 365 * 100
%(D)
figure;
subplot(2,1,1);
plot(orders);
subplot(2,1,2);
plot(total_time);
%(E)
figure;
scatter(orders, total_time);

