문제7
clc;clear;
%(A)
rng(42);
inter = -8 * log(rand(1, 300))
arrive = cumsum(inter)

%(B)
service = 10 + 3 * randn(1, 300)
service(service < 0) = 1

%(C)
start_t = zeros(1, 300);
end_t = zeros(1, 300);
start_t(1) = arrive(1);
end_t(1) = start_t(1) + service(1);
for i = 2:300
    start_t(i) = max(arrive(i), end_t(i-1));
    end_t(i) = start_t(i) + service(i);
end

%(D)
wait = start_t - arrive;

%(E)
mean(wait)
max(wait)
sum(wait > 20) / 300
hist(wait);

